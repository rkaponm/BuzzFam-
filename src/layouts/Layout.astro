---
export interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'BuzzFam Advertising',
  description = 'BuzzFam Advertising — creative campaigns, media buying, and brand strategy that get your business buzzing.',
} = Astro.props;

const canonical = new URL(Astro.url.pathname, Astro.site);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />

    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
  </head>
  <body>
    <slot />
  </body>
</html>

<style is:global>
  :root {
    --bf-bg: #0d0b1f;
    --bf-bg-soft: #16132e;
    --bf-accent: #ffd60a;
    --bf-accent-2: #ff5da2;
    --bf-text: #f4f3fb;
    --bf-text-muted: #b6b2d6;
    --bf-max: 1120px;
    --bf-radius: 16px;
    font-family: system-ui, -apple-system, 'Segoe UI', Roboto, Helvetica, Arial,
      sans-serif;
  }

  * {
    box-sizing: border-box;
  }

  html {
    scroll-behavior: smooth;
  }

  body {
    margin: 0;
    background: var(--bf-bg);
    color: var(--bf-text);
    line-height: 1.6;
    -webkit-font-smoothing: antialiased;
  }

  a {
    color: inherit;
    text-decoration: none;
  }

  h1,
  h2,
  h3 {
    line-height: 1.15;
    margin: 0 0 0.5em;
  }

  .container {
    width: 100%;
    max-width: var(--bf-max);
    margin-inline: auto;
    padding-inline: 1.25rem;
  }

  .btn {
    display: inline-block;
    padding: 0.85rem 1.6rem;
    border-radius: 999px;
    font-weight: 700;
    transition: transform 0.15s ease, box-shadow 0.15s ease;
  }

  .btn-primary {
    background: var(--bf-accent);
    color: #1a1530;
    box-shadow: 0 8px 24px rgba(255, 214, 10, 0.25);
  }

  .btn-primary:hover {
    transform: translateY(-2px);
    box-shadow: 0 12px 28px rgba(255, 214, 10, 0.35);
  }

  .btn-ghost {
    border: 1.5px solid rgba(244, 243, 251, 0.35);
  }

  .btn-ghost:hover {
    border-color: var(--bf-accent);
    color: var(--bf-accent);
  }
</style>
