---
const links = [
  { href: '#services', label: 'Services' },
  { href: '#work', label: 'Work' },
  { href: '#about', label: 'About' },
  { href: '#contact', label: 'Contact' },
];
---

<header class="site-header">
  <div class="container header-inner">
    <a href="/" class="brand" aria-label="BuzzFam Advertising home">
      <span class="brand-mark" aria-hidden="true">🐝</span>
      <span class="brand-name">BuzzFam</span>
    </a>
    <nav aria-label="Primary">
      <ul>
        {links.map((l) => <li><a href={l.href}>{l.label}</a></li>)}
      </ul>
    </nav>
    <a href="#contact" class="btn btn-primary header-cta">Get a quote</a>
  </div>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 10;
    backdrop-filter: blur(10px);
    background: rgba(13, 11, 31, 0.72);
    border-bottom: 1px solid rgba(244, 243, 251, 0.08);
  }

  .header-inner {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    height: 68px;
  }

  .brand {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-weight: 800;
    font-size: 1.25rem;
  }

  .brand-mark {
    font-size: 1.4rem;
  }

  nav {
    margin-left: auto;
  }

  nav ul {
    display: flex;
    gap: 1.5rem;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  nav a {
    color: var(--bf-text-muted);
    font-weight: 600;
    transition: color 0.15s ease;
  }

  nav a:hover {
    color: var(--bf-text);
  }

  .header-cta {
    padding: 0.55rem 1.1rem;
  }

  @media (max-width: 720px) {
    nav,
    .header-cta {
      display: none;
    }
  }
</style>
